<!-- ============================================================
     Deal Carousel (tombstones) — Properties + Data
     ============================================================
     Replaces three stacked Teamsite components — a rich-text
     heading block, the creds-carousel, and a rich-text CTA
     button — with one component that owns all three.

     DCR-DRIVEN. There are no hand-typed card fields. Each card
     binds ONE deal DCR (the press_release type) with a
     Type="DCR" picker, exactly as featured-conferences binds the
     Events List. The author picks a deal; the card renders from
     that deal's own fields and stays in sync when it is edited.

     Fields read from the bound DCR (per the datacapture config):
       date_announced   the deal date  (falls back to publish_date)
       thumbnail        the logo lockup (ONE image; a multi-brand
                        lockup is baked into the asset itself)
       dealvalue        the big number
       clients          the brand names
       role             RBC's role
       transactiontype  the kind of deal
       link             external URL, if the deal has no page

     Deploy alongside the skin:
       /assets/rbccm/css/components/deal-carousel.css
       /assets/rbccm/js/components/deal-carousel.js

     jQuery + slick (accessible-slick) are already site-wide.

     SCHEMA NOTE: only ID, Name, Type are permitted on a Datum,
     and only ID, Name, Replicatable, CloneGroupID on a Group.
     MinReplicates and Required are NOT in Teamsite's schema and
     will fail validation ("Attribute 'MinReplicates' is not
     allowed to appear in element 'Group'"). Counts and required
     fields are enforced in the XSL instead.
     ============================================================ -->
<Properties ComponentID="deal-carousel-v1">

  <!-- ─── Copy (both optional) ───
       The XSL drops the whole header block when neither is filled in — no empty
       <h2>, no empty <p>, and no empty wrapper (which would still be a flex
       child and leave a phantom gap above the cards). -->
  <Datum ID="Heading" Type="String" Name="Section Heading">Proven impact, trusted partnerships</Datum>
  <Datum ID="Intro" Type="Textarea" Name="Intro Text">Explore select recent leading global equity transactions.</Datum>

  <!-- ─── Behaviour ───
       Cards per page, per breakpoint. Matches the legacy slick config
       (3 / 2 / 1), but NOT its paging: the legacy showed 3 and scrolled 1, which
       produced one dot PER DEAL — fifteen dots for fifteen deals. Here a page is
       a full row, so fifteen deals at 3-up give five dots. -->
  <Datum ID="PerViewDesktop" Type="Number" Name="Cards Per Page Desktop">3</Datum>
  <Datum ID="PerViewTablet"  Type="Number" Name="Cards Per Page Tablet">2</Datum>
  <Datum ID="PerViewMobile"  Type="Number" Name="Cards Per Page Mobile">1</Datum>

  <!-- Infinite looping. Matches the legacy (infinite: true). -->
  <Datum ID="Loop" Type="Boolean" Name="Infinite Loop">true</Datum>

  <!-- Auto-advance. OFF by default and deliberately so: these are reference
       tombstones, not a promo unit, and content that moves on its own while
       someone is reading a deal value is hostile. Respects
       prefers-reduced-motion and pauses on hover/focus when enabled. -->
  <Datum ID="Autoplay" Type="Boolean" Name="Autoplay">false</Datum>

  <!-- ═══ WHAT THE CARD SHOWS ═══════════════════════════════════════════════
       Each line on the card is an independent on/off. Nothing is inferred from
       what happens to be filled in.

       This replaces an earlier "cascade" that shuffled description, clients,
       role and transactiontype between two slots depending on which were
       populated. It was reverse-engineered from the LEGACY creds-carousel, whose
       markup was hand-typed HTML and therefore evidence of nothing. It produced
       different cards for different deals with no way to predict which, and no
       way for an author to override it. Explicit toggles instead.

       A line that is switched ON but whose field is EMPTY renders nothing — no
       blank paragraph, no phantom gap. So turning everything on is safe: you get
       whatever that deal actually has.

       Render order under the deal value, top to bottom:
         Title, Description, Clients   (bold grey, 16/700)
         Role                          (bright blue, 18/400)
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- The TITLE. On by default, and this is the one that matters against real
       data: on nearly every live deal the `description` is EMPTY and the `title`
       carries the sentence ("Vault Minerals has entered into a binding agreement
       to merge with Regis Resources..."). The production deals component does not
       read description at all — it renders the title into its `deal-desc` slot.
       So a card with only description switched on would come up blank on most
       deals. -->
  <Datum ID="ShowTitle" Type="Boolean" Name="Show Title">true</Datum>

  <!-- The DESCRIPTION. Also on: where an author has bothered to write one, it is
       better copy than the title.

       If a deal has BOTH, BOTH render, as two lines. That is deliberate and
       predictable — switch one off if you do not want it. The alternative was to
       silently pick one, which is exactly the guessing this replaced. -->
  <Datum ID="ShowDescription" Type="Boolean" Name="Show Description">true</Datum>

  <!-- The CLIENT names ("Woodside Energy &amp; Stone Peak"). Off by default because
       not one deal in the live feed populates it — but the field exists, so the
       option does too. -->
  <Datum ID="ShowClients" Type="Boolean" Name="Show Clients">false</Datum>

  <!-- RBC's ROLE ("Exclusive Financial Advisor"). The bright blue line. -->
  <Datum ID="ShowRole" Type="Boolean" Name="Show Role">true</Datum>

  <!-- ─── Card link ───
       One label for every card. Blank = no links on any card. The destination
       comes from each deal DCR (or its per-card override below), so the label is
       the only thing an author sets here. -->
  <Datum ID="ReadMoreLabel" Type="String" Name="Card Link Label">Read More</Datum>

  <!-- ─── Where a deal page lives ───
       A deal with its OWN page stores no URL: the datacapture config makes
       `content` and `link` mutually exclusive, so filling in the write-up leaves
       `link` empty. Exactly the deals worth linking to are the ones with nothing
       to link to.

       So the XSL rebuilds the path from the DCR's own getFilename() rule —
       base + YYYY / MM / slug(title) + suffix, with the year and month taken
       from publish_date. No author effort, and it cannot go stale.

       The URL is the DCR's own PATH, with the templatedata prefix swapped for
       the public base. This is not a guess: it is what the production deals
       component (the search-driven tombstone grid) already does.

         concat('/en/expertise/transactions/deals/',
                substring-after(@path, 'templatedata/rbccm/deals/data/'))

       DO NOT rebuild the filename from the title. An earlier version of this
       component did, faithfully reproducing the DCR's getFilename() rule, and it
       matched 2 of the 15 deals in the live feed. Titles get edited after
       creation while the filename stays frozen, filenames get truncated, and
       some are simply hand typed (a deal titled "Diamondback Energy completes
       acquisition of Double Eagle" lives at "diamond_deal_tile"). The path must
       be read, never recomputed.

       Kept as Datums so a routing change stays a config change. -->
  <Datum ID="DealBaseUrl" Type="String" Name="Deal Page Base URL">/en/expertise/transactions/deals/</Datum>
  <Datum ID="DcrPathPrefix" Type="String" Name="Templatedata Prefix">templatedata/rbccm/deals/data/</Datum>
  <Datum ID="DealUrlSuffix" Type="String" Name="Deal Page URL Suffix"></Datum>

  <!-- ═══ APPEARANCE ═══════════════════════════════════════════════════════
       Same options as icon-carousel, configured the same way on purpose: an
       author who has set up one of these components should not have to learn a
       second vocabulary for the next.

       ColorScheme and HeadingAlignment are INDEPENDENT. Centred headings on a
       light section, or left-aligned on a tinted one, are both valid.
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- light (default) | tinted | dark
       Three values, where icon-carousel has two, because the comp ships this
       section in two flavours that are NOT light-vs-dark:

         light   white section, the styleguide "Wire" version
         tinted  pale blue wash, the "Transaction Section UI" version
                 (Blue-Light-Blue, #E7EEF1)
         dark    dark blue section, white chrome, for parity with the other
                 carousels

       Tinted is not a shade of dark: the cards stay white and the text stays
       dark blue, which is precisely what makes the white tombstones read as
       raised off the wash. Folding it into `dark` would have inverted text that
       must not invert.

       Parsed case-insensitively, and `light` is the fallback for anything
       unrecognised — a typo should give you the default section, not a broken
       one. -->
  <Datum ID="ColorScheme" Type="String" Name="Color Scheme">light</Datum>

  <!-- left (default) | center
       The styleguide comp left-aligns. The LIVE ECM page centres it, using a
       hand-typed inline style="text-align:center" on both the h2 and the p —
       which is exactly the sort of thing this component exists to delete. Now
       it is a Datum. Accepts "center" or "centered", any casing. -->
  <Datum ID="HeadingAlignment" Type="String" Name="Heading Alignment">left</Datum>

  <!-- Optional background image, layered over the ColorScheme colour. The XSL
       writes these as inline background-* properties, and the stylesheet sets
       its colours with `background-color` rather than the `background`
       shorthand precisely so the two can coexist — the shorthand would reset
       the image to none. -->
  <Datum ID="BackgroundImage" Type="Image" Name="Background Image">
    <Image>
      <Path/>
      <Description/>
    </Image>
  </Datum>
  <Datum ID="BackgroundImagePosition" Type="String" Name="Background Image Position"></Datum>
  <Datum ID="BackgroundImageSize"     Type="String" Name="Background Image Size"></Datum>
  <Datum ID="BackgroundImageRepeat"   Type="String" Name="Background Image Repeat"></Datum>

  <!-- ─── Accessibility ───
       RegionLabel is accessible-slick's `regionLabel`. It matters when a page
       carries more than one carousel: without distinct labels a screen reader
       announces two identical "region"s and the user cannot tell them apart.
       Blank falls back to the Section Heading, then to a generic label. -->
  <Datum ID="RegionLabel" Type="String" Name="Carousel Region Aria Label"></Datum>
  <Datum ID="CarouselAriaLabel" Type="String" Name="Carousel Aria Label"></Datum>
  <Datum ID="InstructionsText" Type="String" Name="Screen Reader Instructions"></Datum>
  <Datum ID="PrevArrowAriaLabel" Type="String" Name="Prev Arrow Aria Label"></Datum>
  <Datum ID="NextArrowAriaLabel" Type="String" Name="Next Arrow Aria Label"></Datum>

  <!-- ─── CTA (optional) ───
       Was a separate rich-text component holding a hand-written <a class="btn">
       wrapped in a <span style="color:#ffffff">. Now a real Datum-driven button.

       Blank link = NO button at all. The label alone will not render one — a
       button that goes nowhere is worse than no button. -->
  <Datum ID="CtaLabel" Type="String" Name="CTA Button Label">More transactions</Datum>
  <Datum ID="CtaLink" Type="String" Name="CTA Button Link">/en/expertise/transactions</Datum>
  <Datum ID="CtaNewTab" Type="Boolean" Name="Open CTA In New Tab">false</Datum>

  <!-- Analytics hook. The legacy carried data-event-tag="ESG_T1APN1" on the
       anchor; kept as a Datum so it is not lost, and so a different page can set
       its own. Blank emits no attribute. -->
  <Datum ID="CtaEventTag" Type="String" Name="CTA Event Tag"></Datum>

  <!-- ─── Section padding (optional overrides) ───
       Same pattern as filter-by: blank uses the baked-in default, or supply any
       CSS length. The XSL writes these as CSS custom properties on the section,
       so the stylesheet keeps its defaults and an override is a one-Datum change.

       This is what replaces the legacy's inline `margin-top: 75px;
       margin-bottom: 5%` — a percentage margin resolves against the PARENT
       WIDTH, not height, so that bottom gap grew on wide screens and collapsed
       on narrow ones. -->
  <Datum ID="PadTopMobile"     Type="String" Name="Mobile Padding Top"/>
  <Datum ID="PadBottomMobile"  Type="String" Name="Mobile Padding Bottom"/>
  <Datum ID="PadTopDesktop"    Type="String" Name="Desktop Padding Top"/>
  <Datum ID="PadBottomDesktop" Type="String" Name="Desktop Padding Bottom"/>

</Properties>

<Data>

  <!-- ══ DEAL CARDS ══════════════════════════════════════════════════════
       One Group per tombstone. Each Group binds ONE deal DCR.

       MINIMUM 1, enforced by the XSL — it renders nothing at all with none.
       No maximum: slick derives the page and dot count from however many exist.

       A card whose DCR has no dealvalue is skipped and does not count toward the
       minimum: a tombstone with no number on it is not a tombstone.

       IMPORTANT — Datum @Name attributes MUST match the XSL's @Name selectors.
       Teamsite strips @ID on replicated Datums, so @Name is the only reliable
       match inside a Replicatable Group. Keep them plain: no apostrophes (they
       break the single-quoted XPath), no em-dashes.
       ═══════════════════════════════════════════════════════════════════ -->
  <Group ID="Deal"
         Name="Deal"
         Replicatable="true"
         CloneGroupID="deal-carousel-card">

    <!-- The picker. OPTIONAL — leave it empty and type the fields by hand below.

         Teamsite fills in the path when the author chooses a deal; the Category
         and Type below scope WHICH deals they can choose from.

         Same binding featured-conferences uses for its Events List:
           <DCR Category="about-us" Type="conferences">templatedata/about-us/conferences/data</DCR>

         Note the asymmetry, because it will bite whoever edits the XSL next: the
         picker is scoped by the TEMPLATEDATA path (rbccm/deals), but the XML
         tree it hands back is rooted at the DCR's own root-container element,
         which the datacapture config names `press_release` — not `deals`. So the
         XSL selects

           Datum[@Name='Deal Record']/DCR/press_release

         Those two names do not have to agree, and here they do not. -->
    <!-- The DCR element is EMPTY. This matters, and it is the same lesson as the
         <Image> skeleton below.

         It used to default to:

           <DCR Category="rbccm" Type="deals">templatedata/rbccm/deals/data</DCR>

         which is NOT a DCR. It is the FOLDER the deal records live under
         (.../data/2026/06/fervo_energy...). featured-conferences can point at
         templatedata/about-us/conferences/data because that genuinely is a single
         record; deals are one record per file, so there is nothing at that path.

         Every card therefore declared a dependency on a DCR that does not exist,
         and every cloned row inherited it from this default, even rows where the
         author never touched the picker. PREVIEW does not care: it finds nothing
         and renders the override fields. PUBLISH walks dependencies and has to
         resolve every referenced DCR, so it fails.

         Category and Type still scope which records the picker offers. The path
         is filled in by Teamsite when an author actually chooses one. -->
    <Datum ID="DealRecord" Type="DCR" Name="Deal Record">
      <DCR Category="rbccm" Type="deals"></DCR>
    </Datum>

    <!-- ══ PER-CARD OVERRIDES ══════════════════════════════════════════════
         EVERY field on the card can be typed in by hand here.

         Each one is BLANK by default, and blank means "use the bound deal
         record". So a card can be:

           fully DCR-driven   pick a deal, fill in nothing. Everything comes
                              from the record and stays in sync when it is edited.
           fully MANUAL       leave the picker empty, type all the fields. Use
                              this for a deal that has no record, or when the
                              record does not carry what the carousel needs.
           MIXED              pick a deal and override the one or two fields that
                              are wrong or missing.

         An override always wins over the record. It never merges.

         NOTE: a manual card needs a Deal Value (below) and nothing else — that
         is the one field the XSL treats as "is this a real card". Everything
         else renders only if present.
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- ── The date ──
         Free text, used VERBATIM. The record's date is YYYY-MM-DD and the XSL
         turns it into "May 2026"; this bypasses that entirely, so type exactly
         what should appear ("May 2026", "Q2 2026", whatever). -->
    <Datum ID="DateOverride" Type="String" Name="Date"></Datum>

    <!-- Appended to the date as "October 2024 | NASDAQ". There is NO exchange
         field anywhere in the deal record — that suffix was hand-typed into the
         old hardcoded carousel markup, which is why it can only ever be typed
         here. Blank shows the date alone, as the styleguide card does. -->
    <Datum ID="Exchange" Type="String" Name="Exchange"></Datum>

    <!-- ── The logo ──
         The nested <Image> skeleton is REQUIRED and must be left EMPTY. Putting
         a default path in it is what made past-speakers-attendees fail
         validation with "Datum ID=[Image] Value is not a valid image". -->
    <Datum ID="LogoOverride" Type="Image" Name="Logo">
      <Image>
        <Path/>
        <Description/>
      </Image>
    </Datum>

    <!-- The logo's alt text. Blank falls back to the title, which is what names
         the deal for a screen-reader user. The legacy hardcoded aria-label="SMS
         Logo" on every logo on every card, so fifteen different companies were
         all announced as "SMS Logo". -->
    <Datum ID="LogoAltOverride" Type="String" Name="Logo Alt Text"></Datum>

    <!-- ── The body ──
         Deal Value is the big number, and it is the ONE field that makes a card
         a card. A card with no value here AND no value on its record is dropped
         entirely: a tombstone with no number on it is not a tombstone. -->
    <Datum ID="ValueOverride" Type="String" Name="Deal Value"></Datum>

    <!-- The bold grey lines. Which of these actually render is controlled by the
         Show Title / Show Description / Show Clients switches above; these only
         change WHAT they say. -->
    <Datum ID="TitleOverride" Type="String" Name="Title"></Datum>
    <Datum ID="DescriptionOverride" Type="Textarea" Name="Description"></Datum>
    <Datum ID="ClientsOverride" Type="String" Name="Client Names"></Datum>

    <!-- The bright blue line. -->
    <Datum ID="RoleOverride" Type="String" Name="Role"></Datum>

    <!-- ── The link ──
         Blank resolves, in order: the record's own `link` field (set only when
         the deal points somewhere EXTERNAL), then the deal's own page, mapped
         from its DCR path. Set this to override both. A manual card with no
         record has nothing to fall back on, so it needs this or it renders no
         link at all. -->
    <Datum ID="LinkOverride" Type="String" Name="Card Link URL"></Datum>
    <Datum ID="LinkNewTab" Type="Boolean" Name="Open Card Link In New Tab">false</Datum>

  </Group>

</Data>
