<!-- ============================================================
     Icon Carousel — Properties + Data
     ============================================================
     Component-level authoring inputs (Properties) and the
     repeatable icon/label rows (Data).

     Consumed by icon-carousel.xsl.

     Depends on:
       /assets/rbccm/css/components/icon-carousel.css   (deploy this)
       jQuery + slick (accessible-slick) — already site-wide

     The component JS is inlined in the skin; no separate JS file.
     ============================================================ -->
<Properties ComponentID="icon-carousel-v1">

  <!-- ─── Copy (both optional) ───
       Heading and intro are independently optional, and the XSL drops the
       whole header block when neither is filled in — no empty <h2>, no empty
       <p>, and no empty wrapper div either (an empty wrapper would still be a
       flex child and leave a phantom 64px gap above the carousel).

       All four combinations render correctly: both, heading only, intro only,
       neither (carousel alone, sitting flush under whatever precedes it).

       No default copy on purpose. This is a generic component now, not the ECM
       one — a baked-in "Equity Capital Markets…" default would quietly ship
       that heading onto any other page an author drops this on. -->
  <Datum ID="Heading" Type="String" Name="Section Heading (optional)"></Datum>

  <!-- Textarea: the comp's standfirst runs long and may want inline markup. -->
  <Datum ID="Intro" Type="Textarea" Name="Intro / Standfirst (optional)"></Datum>

  <!-- ─── Behaviour ───
       Items per slide, per breakpoint. The XSL passes these straight
       through to the data attributes the JS reads; it re-chunks the
       flat item list on resize, so these are the ONLY place the slide
       count is decided. Authors never group items into slides.

       Defaults match the Figma comp: 4 across on desktop, 4 stacked on
       mobile. Tablet is 2 because 4 across at 768–991px squeezes the
       longer sector names. -->
  <Datum ID="PerViewDesktop" Type="Number" Name="Items per slide — desktop (992px+)">4</Datum>
  <Datum ID="PerViewTablet"  Type="Number" Name="Items per slide — tablet (768–991px)">2</Datum>
  <Datum ID="PerViewMobile"  Type="Number" Name="Items per slide — mobile (under 768px)">4</Datum>

  <!-- Infinite looping. When on, the carousel wraps past the ends, the
       arrows never disable, AND a short final slide is padded with the
       leading items so there's no empty cell (11 items at 4-per-slide
       would otherwise leave a hole). Recommended ON for this reason. -->
  <Datum ID="Loop" Type="Boolean" Name="Infinite loop (wrap past the ends)">true</Datum>

  <!-- Auto-advance. OFF by default and deliberately so: this is
       reference content, not a promo unit. The legacy Bootstrap
       carousel auto-advanced (data-ride="carousel") and moved the
       content out from under people mid-read. Respects
       prefers-reduced-motion and pauses on hover/focus when enabled. -->
  <Datum ID="Autoplay" Type="Boolean" Name="Auto-advance slides">false</Datum>


  <!-- ─── Appearance ───
       Same modifier system as the leadership slider, same Datum names and
       same BEM modifier suffixes, so the two components are configured
       identically:

         ColorScheme = dark        adds the "on-dark" modifier class
         HeadingAlignment = center adds the "headings-centered" modifier class

       (Written out in words because an XML comment may not contain a double
       hyphen, so the literal BEM class names can't be quoted here.)

       The two are deliberately INDEPENDENT: an author can centre the headings
       on a light section, or left-align them on a dark one. -->
  <Datum ID="ColorScheme" Type="String" Name="Color Scheme (light or dark)">light</Datum>
  <Datum ID="HeadingAlignment" Type="String" Name="Heading Alignment (left or center)">left</Datum>

  <!-- Item layout. Two ways to arrange the icon against its label:

         inline   (default) icon BESIDE the label, pair left-aligned in its
                  column. This is what the Figma comp specs.
         centered icon ABOVE the label, both centred in the column. Reads as a
                  tile rather than a list row.

       "centered" suits short labels ("Energy", "Healthcare") and looks
       deliberate with 4 across. Be aware it costs vertical space and that a
       long label — "Power, Utilities & Infrastructure" — will wrap to two or
       three centred lines, which makes the row noticeably taller. The inline
       default absorbs long labels far more gracefully.

       Independent of ColorScheme and HeadingAlignment; any combination is
       valid. Applies at every breakpoint, including the mobile stack. -->
  <Datum ID="ItemAlignment" Type="String" Name="Item Layout (inline or centered)">inline</Datum>

  <!-- Background image (optional). Layers over the section's background
       colour, so it composites correctly with ColorScheme=dark.

       The three modifiers below only take effect when an image is set; the
       XSL defaults them to center center / cover / no-repeat, which is what
       the leadership banner uses. Leave them blank unless the art direction
       needs otherwise.

       NOTE: this is a Type="Image" asset picker, whereas leadership uses a
       plain String URL. Same reasoning as the item icons — the picker works
       given the empty <Image> skeleton below. Authors get a browse dialog
       instead of pasting /assets/rbccm/images/... by hand. -->
  <Datum ID="BackgroundImage" Type="Image" Name="Background Image">
    <Image>
      <Path/>
      <Description/>
    </Image>
  </Datum>
  <Datum ID="BackgroundImagePosition" Type="String" Name="Background Image Position (default: center center)"></Datum>
  <Datum ID="BackgroundImageSize"     Type="String" Name="Background Image Size (default: cover)"></Datum>
  <Datum ID="BackgroundImageRepeat"   Type="String" Name="Background Image Repeat (default: no-repeat)"></Datum>

  <!-- ─── Section padding (optional overrides) ───
       Same pattern as filter-by: leave blank to use the baked-in default,
       or supply any CSS length (e.g. "80px", "5rem", "0") to override.

       The XSL writes these out as CSS custom properties on the section, so
       the stylesheet keeps its defaults and an override is a one-Datum change
       with no CSS edit. Blank Datums emit nothing at all — the var() fallback
       in the CSS is what supplies the default.

       Note leadership has no equivalent; filter-by is the precedent here.

       Horizontal padding is deliberately NOT exposed. The side gutters are
       load-bearing: they're where the arrows live, outside the 1100px rail.
       An author setting a large left/right padding would clamp the content box
       and pull the arrows back inside the rail, squeezing the icon grid. If a
       page ever needs a different rail width, that's a CSS change, not a Datum. -->
  <Datum ID="PadTopMobile"     Type="String" Name="Mobile padding-top (blank = 40px)"/>
  <Datum ID="PadBottomMobile"  Type="String" Name="Mobile padding-bottom (blank = 40px)"/>
  <Datum ID="PadTopDesktop"    Type="String" Name="Desktop padding-top (blank = 64px)"/>
  <Datum ID="PadBottomDesktop" Type="String" Name="Desktop padding-bottom (blank = 64px)"/>

  <!-- ─── Accessibility ───

       RegionLabel — the aria-label on the carousel's region wrapper. This is
       accessible-slick's `regionLabel` setting, and it matters most when a page
       has MORE THAN ONE carousel: without distinct labels a screen reader
       announces two identical "region"s and the user can't tell them apart.
       Blank falls back to the Section Heading, then to a generic label.

       InstructionsText — accessible-slick's `instructionsText`. Optional
       screen-reader-only text emitted at the START of the carousel, explaining
       any behaviour that isn't obvious. Blank by default and that is the right
       default here: this carousel's behaviour IS obvious (Prev / Next / numbered
       dot buttons, all reachable by Tab), and there is no arrow-key handling to
       explain. Fill it in only for genuinely non-obvious behaviour — e.g. if two
       carousels are ever synced, say so. Per accessible-slick's own tip, reuse
       the RegionLabel wording here so users know what to listen for. -->
  <Datum ID="RegionLabel" Type="String" Name="Carousel Region Aria Label (blank = section heading)"></Datum>
  <Datum ID="InstructionsText" Type="String" Name="Screen-reader Instructions (blank = none)"></Datum>

  <!-- All optional. Sensible defaults are baked into the XSL; fill
       these in only when the generic wording isn't right for the page. -->
  <Datum ID="CarouselAriaLabel" Type="String" Name="Carousel Aria Label (override)"></Datum>
  <Datum ID="PrevArrowAriaLabel" Type="String" Name="Prev Arrow Aria Label (override)"></Datum>
  <Datum ID="NextArrowAriaLabel" Type="String" Name="Next Arrow Aria Label (override)"></Datum>

</Properties>

<Data>

  <!-- ── ICON ITEMS ──
       One Group per icon + label pair.

       MINIMUM 4, enforced by the XSL — it renders nothing at all with
       fewer, because the layout is a 4-across row on desktop and 1-3
       items would leave dead cells. No maximum: slick derives the page
       and dot count from however many exist, so adding a twelfth sector
       needs no code change anywhere.

       NOTE: the minimum is NOT declared here as MinReplicates. Teamsite's
       schema rejects that attribute ("Attribute 'MinReplicates' is not
       allowed to appear in element 'Group'"), and no working component in
       this codebase uses it. Same for Required on a Datum. Only ID, Name,
       Type are permitted on Datum; only ID, Name, Replicatable,
       CloneGroupID on Group. Validation lives in the XSL, not the schema.

       IMPORTANT — Datum @Name attributes MUST match the XSL's @Name
       selectors. Teamsite strips @ID on replicated Datums, so @Name is
       the only reliable match inside a Replicatable Group. Same trap
       documented in past-speakers-attendees. -->
  <Group ID="IconItem"
         Name="Icon Item"
         Replicatable="true"
         CloneGroupID="icon-carousel-item">

    <!-- Asset picker. The nested <Image> skeleton is REQUIRED and must
         be left empty here — do not put a default path in it.

         A previous attempt to use Type="Image" in past-speakers-attendees
         was rolled back after the validator threw "Datum ID=[Image] Value
         is not a valid image". That failure was the schema, not the picker:
         Type="Image" needs this exact empty Path/Description skeleton, as
         proven by imagine-2025/components/themes. Copy it verbatim.

         The XSL reads the path from Datum[@Name='Icon']/Image/Path. -->
    <Datum ID="Icon" Type="Image" Name="Icon">
      <Image Width="40" Height="40">
        <Path/>
        <Description/>
      </Image>
    </Datum>

    <!-- Dark-background variant of the same icon (e.g. icon-energy-dark.svg,
         with the navy strokes redrawn in white and the yellow accent kept).

         WHY a second file rather than a CSS trick: the icons are referenced as
         <img src="*.svg">, and CSS cannot reach inside an image to recolour it.
         A `filter: brightness(0) invert(1)` would work but flattens everything
         to solid white and destroys the yellow accent.

         The XSL selects this AUTOMATICALLY whenever ColorScheme = dark — the
         author never picks a variant, so nobody can pair a navy icon with a
         navy background by mistake.

         Optional. If ColorScheme is dark and this is blank, the light icon is
         used as a fallback, which will be low-contrast. Fill it in for any
         section that runs dark. -->
    <Datum ID="IconDark" Type="Image" Name="Icon Dark Variant">
      <Image Width="40" Height="40">
        <Path/>
        <Description/>
      </Image>
    </Datum>

    <!-- Decorative by default: the label next to the icon already names
         the sector, so a matching alt would make a screen reader say it
         twice. Leave BLANK unless the icon carries meaning the label
         doesn't. The XSL emits alt="" when this is empty. -->
    <Datum ID="IconAlt" Type="String" Name="Icon Alt Text"></Datum>

    <!-- Required in practice: a row with no label is skipped by the XSL and
         does not count toward the minimum of 4. (Teamsite's schema has no
         Required attribute, so this is enforced in the template.) -->
    <Datum ID="Label" Type="String" Name="Label">Sector name</Datum>

  </Group>

</Data>
