<Data>
  <!-- Min 4, max 8 slides. Component will not render outside those bounds. -->

  <Group ID="LeadershipSlide" Name="Leadership Slide" Replicatable="true" CloneGroupID="leadership-slide">
    <Datum ID="Name" Type="String" Name="Person Name">
      <!-- e.g. "Sian Hurrell" -->
    </Datum>
    <Datum ID="Role" Type="String" Name="Role / Title">
      <!-- e.g. "Head, Co-CEO Europe And Head Of Capital Markets Europe" -->
    </Datum>
    <Datum ID="Image" Type="String" Name="Headshot Image">
      <!-- Path to webp image e.g. /assets/rbccm/images/leadership/sian-hurrell.webp -->
      <!-- Leave empty to show placeholder -->
    </Datum>
    <Datum ID="ImageAlt" Type="String" Name="Image Alt Text">
      <!-- e.g. "Sian Hurrell" — should match Person Name -->
    </Datum>
    <Datum ID="LinkedInHandle" Type="String" Name="LinkedIn Handle">
      <!-- Handle only e.g. "sian-hurrell" — prepended with https://www.linkedin.com/in/ -->
      <!-- Leave empty to hide LinkedIn icon -->
    </Datum>
  </Group>

</Data>
